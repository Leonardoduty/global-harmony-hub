# Global Governance AI Simulator — Environment Variables
# Copy this file to .env and fill in your keys for local development.
# On Replit, set these via the Secrets panel instead.

# Option A: Standard OpenAI key (sk-...)
OPENAI_API_KEY=sk-...

# Option B: OpenRouter key (sk-or-...) — can be placed in OPENAI_API_KEY
# The server detects sk-or- prefix and routes it to OpenRouter automatically.
# OPENAI_API_KEY=sk-or-...

# Option C: Separate OpenRouter key (takes priority if set)
# OPENROUTER_API_KEY=sk-or-...

# Optional: fallback OpenAI key if primary is an OpenRouter key
# OPENAI_BACKUP_KEY=sk-...
